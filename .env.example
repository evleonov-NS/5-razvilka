# --- База данных (Neon) ---
# pooled-строка для приложения
DATABASE_URL=
# direct-строка для миграций Prisma
DIRECT_URL=
# рабочая (production) БД для утилиты view-db
DATABASE_URL_PROD=

# --- view-db (dev-утилита) ---
# VIEW_DB_ENABLED=true  # включить /view-db на production (по умолчанию только dev)

# --- Auth (Auth.js v5 + Google) ---
# секрет сессии: npx auth secret (также используется для шифрования user API-ключей)
AUTH_SECRET=
# базовый URL приложения (локально / Vercel)
AUTH_URL=http://localhost:3015
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM: платформа (по умолчанию DeepSeek) ---
# Владелец без лимита (остальные — 1 бесплатный разбор, далее свой ключ в настройках)
OWNER_EMAIL=evleonov79@gmail.com
LLM_DEFAULT_PROVIDER=DEEPSEEK
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
# Опционально — если платформа отдаёт Qwen/OpenAI
QWEN_API_KEY=
OPENAI_API_KEY=
# Устарело: OPENAI_BASE_URL больше не нужен для каталога провайдеров;
# baseURL задаётся в lib/llm/providers.ts (DeepSeek / Qwen / OpenAI).
OPENAI_BASE_URL=

# --- Dev: демо-данные для кабинета (npm run db:seed-demo) ---
# если пусто — берётся последний пользователь Google OAuth в БД
# DEMO_USER_EMAIL=you@gmail.com
