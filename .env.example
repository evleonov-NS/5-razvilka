# --- База данных (Neon) ---
# pooled-строка для приложения
DATABASE_URL=
# direct-строка для миграций Prisma
DIRECT_URL=
# рабочая (production) БД для утилиты view-db
DATABASE_URL_PROD=

# --- view-db (dev-утилита) ---
# VIEW_DB_ENABLED=true  # включить /view-db на production (по умолчанию только dev)

# --- Auth (Auth.js v5 + Google) ---
# секрет сессии: npx auth secret
AUTH_SECRET=
# базовый URL приложения (локально / Vercel)
AUTH_URL=http://localhost:3015
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM (OpenAI-совместимый) ---
OPENAI_API_KEY=
# base URL провайдера. Прямой OpenAI: оставить пустым/дефолт.
# Из РФ для локальной разработки — URL агрегатора/прокси (OpenAI-совместимый).
OPENAI_BASE_URL=
# модель: подешевле — для баланса цена/качество, помощнее — для «умных» сценариев
LLM_MODEL=

# --- Dev: демо-данные для кабинета (npm run db:seed-demo) ---
# если пусто — берётся последний пользователь Google OAuth в БД
# DEMO_USER_EMAIL=you@gmail.com
