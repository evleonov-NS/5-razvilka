generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Временная сущность для smoke-теста деплоя (Этап 0). Удалить после доменной миграции.
model Note {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  createdAt DateTime @default(now())
}
